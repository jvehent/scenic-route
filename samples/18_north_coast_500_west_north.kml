<Folder><name>Start / End</name><Placemark><name>START: Inverness</name><styleUrl>#start</styleUrl><Point><coordinates>-4.224700,57.477800,0</coordinates></Point></Placemark><Placemark><name>END: Thurso</name><styleUrl>#end</styleUrl><Point><coordinates>-3.521500,58.598800,0</coordinates></Point></Placemark></Folder>
<Folder><name>Waypoints</name><Placemark><name>Achnasheen</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.086000,57.578000,0</coordinates></Point></Placemark><Placemark><name>Lochcarron</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.509600,57.403900,0</coordinates></Point></Placemark><Placemark><name>Bealach na Bà summit (626 m)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.691600,57.422100,0</coordinates></Point></Placemark><Placemark><name>Applecross</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.808500,57.433700,0</coordinates></Point></Placemark><Placemark><name>Shieldaig</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.658500,57.516300,0</coordinates></Point></Placemark><Placemark><name>Torridon</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.518000,57.547900,0</coordinates></Point></Placemark><Placemark><name>Kinlochewe</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.311000,57.601000,0</coordinates></Point></Placemark><Placemark><name>Gairloch</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.677000,57.729000,0</coordinates></Point></Placemark><Placemark><name>Ullapool</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.160500,57.894600,0</coordinates></Point></Placemark><Placemark><name>Lochinver</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.244900,58.145700,0</coordinates></Point></Placemark><Placemark><name>Kylesku</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.015000,58.262500,0</coordinates></Point></Placemark><Placemark><name>Scourie</name><styleUrl>#wpt</styleUrl><Point><coordinates>-5.153000,58.352000,0</coordinates></Point></Placemark><Placemark><name>Durness</name><styleUrl>#wpt</styleUrl><Point><coordinates>-4.746800,58.568500,0</coordinates></Point></Placemark><Placemark><name>Tongue</name><styleUrl>#wpt</styleUrl><Point><coordinates>-4.422200,58.475400,0</coordinates></Point></Placemark></Folder>
<Folder><name>Scenic Points</name><Placemark><name>Bealach na Bà</name><styleUrl>#poi</styleUrl><description><![CDATA['Pass of the Cattle' — the highest road in the UK at 626 m and the country's only true alpine-style pass with switchbacks. Caravans banned. In fog or wind, save it for another day.]]></description><Point><coordinates>-5.691600,57.422100,0</coordinates></Point></Placemark><Placemark><name>Applecross</name><styleUrl>#poi</styleUrl><description><![CDATA[Gaelic-speaking village of A' Chomraich. Applecross Inn does the seafood the Highlands are famous for. The view across to Skye at sunset is the cover of every Scottish tourism brochure.]]></description><Point><coordinates>-5.808500,57.433700,0</coordinates></Point></Placemark><Placemark><name>Torridon</name><styleUrl>#poi</styleUrl><description><![CDATA[Surrounded by some of the oldest mountains in Europe — Liathach and Beinn Eighe are ~750 million-year-old Torridonian sandstone, with white quartzite caps glinting in sun.]]></description><Point><coordinates>-5.518000,57.547900,0</coordinates></Point></Placemark><Placemark><name>Ullapool</name><styleUrl>#poi</styleUrl><description><![CDATA[Planned 18th-century herring-fishing town, now ferry port to the Outer Hebrides. The Ceilidh Place hosts excellent live folk music.]]></description><Point><coordinates>-5.160500,57.894600,0</coordinates></Point></Placemark><Placemark><name>Lochinver / Suilven</name><styleUrl>#poi</styleUrl><description><![CDATA[Suilven is a 731 m sandstone monolith that erupts from a treeless bog — it looks like nothing else in Britain. The hike is 22 km return; it's worth a day.]]></description><Point><coordinates>-5.244900,58.145700,0</coordinates></Point></Placemark><Placemark><name>Durness / Smoo Cave</name><styleUrl>#poi</styleUrl><description><![CDATA[Vast sea cave you can walk into; an underground waterfall thunders inside. Ceannabeinne Beach a few km east is white sand and turquoise water — Britain's accidental Caribbean.]]></description><Point><coordinates>-4.746800,58.568500,0</coordinates></Point></Placemark></Folder>
</Document></kml>
