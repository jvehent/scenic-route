<Folder><name>Waypoints</name><Placemark><name>Simpsons Gap</name><styleUrl>#wpt</styleUrl><Point><coordinates>133.715600,-23.681700,0</coordinates></Point></Placemark><Placemark><name>Standley Chasm</name><styleUrl>#wpt</styleUrl><Point><coordinates>133.496900,-23.763900,0</coordinates></Point></Placemark><Placemark><name>Ellery Creek Big Hole</name><styleUrl>#wpt</styleUrl><Point><coordinates>133.008900,-23.751700,0</coordinates></Point></Placemark><Placemark><name>Ormiston Gorge</name><styleUrl>#wpt</styleUrl><Point><coordinates>132.771700,-23.705000,0</coordinates></Point></Placemark><Placemark><name>Glen Helen</name><styleUrl>#wpt</styleUrl><Point><coordinates>132.691700,-23.681700,0</coordinates></Point></Placemark><Placemark><name>Tnorala / Gosse Bluff</name><styleUrl>#wpt</styleUrl><Point><coordinates>132.308300,-23.819700,0</coordinates></Point></Placemark><Placemark><name>Mereenie Loop midpoint</name><styleUrl>#wpt</styleUrl><Point><coordinates>132.050000,-24.150000,0</coordinates></Point></Placemark><Placemark><name>Kings Canyon (Watarrka)</name><styleUrl>#wpt</styleUrl><Point><coordinates>131.556700,-24.258800,0</coordinates></Point></Placemark><Placemark><name>Luritja Road junction</name><styleUrl>#wpt</styleUrl><Point><coordinates>131.412500,-25.012500,0</coordinates></Point></Placemark><Placemark><name>Curtin Springs</name><styleUrl>#wpt</styleUrl><Point><coordinates>131.755800,-25.323100,0</coordinates></Point></Placemark><Placemark><name>Yulara village</name><styleUrl>#wpt</styleUrl><Point><coordinates>130.988900,-25.240600,0</coordinates></Point></Placemark><Placemark><name>Uluru</name><styleUrl>#wpt</styleUrl><Point><coordinates>131.036900,-25.344400,0</coordinates></Point></Placemark><Placemark><name>Kata Tjuta</name><styleUrl>#wpt</styleUrl><Point><coordinates>130.723900,-25.294400,0</coordinates></Point></Placemark><Placemark><name>Erldunda (Stuart Hwy junction)</name><styleUrl>#wpt</styleUrl><Point><coordinates>133.206400,-25.840000,0</coordinates></Point></Placemark></Folder>
<Folder><name>Scenic Points</name><Placemark><name>Standley Chasm</name><styleUrl>#poi</styleUrl><description><![CDATA[9 m-wide gorge that lights up an extraordinary orange for ~30 minutes around midday when the sun reaches the floor. Aboriginal-owned. Small entry fee.]]></description><Point><coordinates>133.496900,-23.763900,0</coordinates></Point></Placemark><Placemark><name>Ormiston Gorge</name><styleUrl>#poi</styleUrl><description><![CDATA[Permanent waterhole flanked by 250 m red walls. 7 km Pound Walk loops up and around — superb. Black-footed rock wallabies on the cliff above the parking lot.]]></description><Point><coordinates>132.771700,-23.705000,0</coordinates></Point></Placemark><Placemark><name>Tnorala / Gosse Bluff</name><styleUrl>#poi</styleUrl><description><![CDATA[5 km-wide circular ridge — the eroded core of a comet impact 142 million years ago. Sacred to Western Arrernte people; restricted areas inside the crater.]]></description><Point><coordinates>132.308300,-23.819700,0</coordinates></Point></Placemark><Placemark><name>Kings Canyon</name><styleUrl>#poi</styleUrl><description><![CDATA[270 m sheer red walls. The 6 km Rim Walk is one of Australia's great hikes — climb the steep first 100 m at dawn and the reward is everything that follows. The Garden of Eden waterhole at the canyon head.]]></description><Point><coordinates>131.556700,-24.258800,0</coordinates></Point></Placemark><Placemark><name>Uluru</name><styleUrl>#poi</styleUrl><description><![CDATA[348 m sandstone monolith, rising from a desert plain that was once an inland sea. 10 km base walk; sunrise viewing area is on the east side; ranger-led Mala Walk explains Anangu Tjukurpa (Law/Dreaming).]]></description><Point><coordinates>131.036900,-25.344400,0</coordinates></Point></Placemark><Placemark><name>Kata Tjuta (The Olgas)</name><styleUrl>#poi</styleUrl><description><![CDATA[36 conglomerate domes rising to 546 m — taller than Uluru and visible from it. The Valley of the Winds walk (7 km loop) goes deep among them; closed by 11 AM if temperatures exceed 36 °C.]]></description><Point><coordinates>130.723900,-25.294400,0</coordinates></Point></Placemark></Folder>
</Document></kml>
