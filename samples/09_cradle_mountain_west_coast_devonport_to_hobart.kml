<Folder><name>Waypoints</name><Placemark><name>Sheffield</name><styleUrl>#wpt</styleUrl><Point><coordinates>146.333300,-41.383300,0</coordinates></Point></Placemark><Placemark><name>Wilmot</name><styleUrl>#wpt</styleUrl><Point><coordinates>146.000000,-41.500000,0</coordinates></Point></Placemark><Placemark><name>Cradle Mountain visitor centre</name><styleUrl>#wpt</styleUrl><Point><coordinates>145.946100,-41.683900,0</coordinates></Point></Placemark><Placemark><name>Dove Lake</name><styleUrl>#wpt</styleUrl><Point><coordinates>145.958300,-41.653100,0</coordinates></Point></Placemark><Placemark><name>Tullah</name><styleUrl>#wpt</styleUrl><Point><coordinates>145.616700,-41.733300,0</coordinates></Point></Placemark><Placemark><name>Rosebery</name><styleUrl>#wpt</styleUrl><Point><coordinates>145.533100,-41.778300,0</coordinates></Point></Placemark><Placemark><name>Zeehan</name><styleUrl>#wpt</styleUrl><Point><coordinates>145.335800,-41.891700,0</coordinates></Point></Placemark><Placemark><name>Strahan</name><styleUrl>#wpt</styleUrl><Point><coordinates>145.330300,-42.156400,0</coordinates></Point></Placemark><Placemark><name>Queenstown</name><styleUrl>#wpt</styleUrl><Point><coordinates>145.555000,-42.081400,0</coordinates></Point></Placemark><Placemark><name>Derwent Bridge</name><styleUrl>#wpt</styleUrl><Point><coordinates>146.220000,-42.130800,0</coordinates></Point></Placemark><Placemark><name>Lake St Clair</name><styleUrl>#wpt</styleUrl><Point><coordinates>146.176900,-42.116700,0</coordinates></Point></Placemark><Placemark><name>Hamilton</name><styleUrl>#wpt</styleUrl><Point><coordinates>146.851400,-42.539400,0</coordinates></Point></Placemark><Placemark><name>New Norfolk</name><styleUrl>#wpt</styleUrl><Point><coordinates>147.050000,-42.783300,0</coordinates></Point></Placemark></Folder>
<Folder><name>Scenic Points</name><Placemark><name>Sheffield</name><styleUrl>#poi</styleUrl><description><![CDATA['Town of Murals.' 60+ outdoor murals tell the story of pioneer settlement; an annual mural-painting festival keeps the collection growing.]]></description><Point><coordinates>146.333300,-41.383300,0</coordinates></Point></Placemark><Placemark><name>Dove Lake / Cradle Mountain</name><styleUrl>#poi</styleUrl><description><![CDATA[6 km flat circuit around the lake with the iconic Cradle Mountain dolerite peak rising behind. Boardwalks the entire way. Shuttle bus from the visitor centre is mandatory in peak season.]]></description><Point><coordinates>145.958300,-41.653100,0</coordinates></Point></Placemark><Placemark><name>Strahan</name><styleUrl>#poi</styleUrl><description><![CDATA[Sarah Island convict settlement reached by Gordon River cruise from the harbour. The Huon pines along the Gordon take 50 years to grow as wide as a finger; some living trees here are 2,500+ years old.]]></description><Point><coordinates>145.330300,-42.156400,0</coordinates></Point></Placemark><Placemark><name>Queenstown</name><styleUrl>#poi</styleUrl><description><![CDATA[Conical bare hills around the town are the visible legacy of 100 years of copper smelting (1893–1994) — sulphur dioxide killed the rainforest, rain washed soil down to bedrock. Slow regrowth now in progress.]]></description><Point><coordinates>145.555000,-42.081400,0</coordinates></Point></Placemark><Placemark><name>Franklin–Gordon Wild Rivers NP</name><styleUrl>#poi</styleUrl><description><![CDATA[Crossed by the Lyell Highway. The 1983 High Court decision stopping a hydro dam on the Franklin River was a turning point in Australian environmental history.]]></description><Point><coordinates>146.220000,-42.130800,0</coordinates></Point></Placemark><Placemark><name>Lake St Clair</name><styleUrl>#poi</styleUrl><description><![CDATA[187 m-deep glacial lake, southern terminus of the Overland Track. Boat taxi to Narcissus Hut; rainforest boardwalk loops near the visitor centre.]]></description><Point><coordinates>146.176900,-42.116700,0</coordinates></Point></Placemark></Folder>
</Document></kml>
