<Folder><name>Waypoints</name><Placemark><name>Mt Locust (MP 15.5)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-91.080000,31.680000,0</coordinates></Point></Placemark><Placemark><name>Rocky Springs (MP 54.8)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-90.785000,32.086000,0</coordinates></Point></Placemark><Placemark><name>Jackson, MS (MP 102)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-90.082000,32.415000,0</coordinates></Point></Placemark><Placemark><name>Cypress Swamp (MP 122)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-89.940000,32.600000,0</coordinates></Point></Placemark><Placemark><name>French Camp (MP 180.7)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-89.406000,33.296000,0</coordinates></Point></Placemark><Placemark><name>Tupelo, MS (MP 266)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-88.703400,34.257600,0</coordinates></Point></Placemark><Placemark><name>Pharr Mounds (MP 286.7)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-88.530000,34.454000,0</coordinates></Point></Placemark><Placemark><name>Colbert Ferry (MP 327.3)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-88.079000,34.786000,0</coordinates></Point></Placemark><Placemark><name>Wichahpi Stone Wall (MP 338)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-87.944000,34.883000,0</coordinates></Point></Placemark><Placemark><name>Meriwether Lewis Site (MP 385.9)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-87.454000,35.516000,0</coordinates></Point></Placemark><Placemark><name>Jackson Falls (MP 404.7)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-87.284000,35.730000,0</coordinates></Point></Placemark></Folder>
<Folder><name>Scenic Points</name><Placemark><name>Mt Locust Inn</name><styleUrl>#poi</styleUrl><description><![CDATA[Oldest standing structure on the Trace. Late-1700s 'stand' inn where boatmen slept on the dirt floor for 25¢.]]></description><Point><coordinates>-91.080000,31.680000,0</coordinates></Point></Placemark><Placemark><name>Rocky Springs</name><styleUrl>#poi</styleUrl><description><![CDATA[Ghost-town site of an 1860 town of 2,600 — yellow fever, soil exhaustion, and the boll weevil killed it. Old church remains.]]></description><Point><coordinates>-90.785000,32.086000,0</coordinates></Point></Placemark><Placemark><name>Cypress Swamp</name><styleUrl>#poi</styleUrl><description><![CDATA[Boardwalk loop through a bald cypress / tupelo swamp — Spanish moss, alligators, prothonotary warblers.]]></description><Point><coordinates>-89.940000,32.600000,0</coordinates></Point></Placemark><Placemark><name>Tupelo</name><styleUrl>#poi</styleUrl><description><![CDATA[Elvis Presley's birthplace (just off the parkway) and Park Service HQ for the Trace. Free visitor center museum.]]></description><Point><coordinates>-88.703400,34.257600,0</coordinates></Point></Placemark><Placemark><name>Pharr Mounds</name><styleUrl>#poi</styleUrl><description><![CDATA[Eight Native American burial mounds spread over 36 ha, built ~1–200 CE. Largely untouched.]]></description><Point><coordinates>-88.530000,34.454000,0</coordinates></Point></Placemark><Placemark><name>Meriwether Lewis grave</name><styleUrl>#poi</styleUrl><description><![CDATA[The Lewis &amp; Clark co-leader died here in 1809 from gunshot wounds — suicide or murder, still debated. Stone monument.]]></description><Point><coordinates>-87.454000,35.516000,0</coordinates></Point></Placemark><Placemark><name>Jackson Falls</name><styleUrl>#poi</styleUrl><description><![CDATA[9 m cascade, 0.5 km steep paved trail to the base. Flow varies; best after rain.]]></description><Point><coordinates>-87.284000,35.730000,0</coordinates></Point></Placemark></Folder>
</Document></kml>
