<Folder><name>Start / End</name><Placemark><name>START: Perth</name><styleUrl>#start</styleUrl><Point><coordinates>115.861300,-31.952300,0</coordinates></Point></Placemark><Placemark><name>END: Kalbarri NP — Nature's Window</name><styleUrl>#end</styleUrl><Point><coordinates>114.169700,-27.655300,0</coordinates></Point></Placemark></Folder>
<Folder><name>Waypoints</name><Placemark><name>Yanchep</name><styleUrl>#wpt</styleUrl><Point><coordinates>115.699700,-31.755300,0</coordinates></Point></Placemark><Placemark><name>Lancelin</name><styleUrl>#wpt</styleUrl><Point><coordinates>115.450000,-31.300000,0</coordinates></Point></Placemark><Placemark><name>Pinnacles / Nambung NP</name><styleUrl>#wpt</styleUrl><Point><coordinates>115.158300,-30.604200,0</coordinates></Point></Placemark><Placemark><name>Cervantes</name><styleUrl>#wpt</styleUrl><Point><coordinates>115.065300,-30.503700,0</coordinates></Point></Placemark><Placemark><name>Jurien Bay</name><styleUrl>#wpt</styleUrl><Point><coordinates>115.039400,-30.304700,0</coordinates></Point></Placemark><Placemark><name>Leeman</name><styleUrl>#wpt</styleUrl><Point><coordinates>114.980600,-29.722200,0</coordinates></Point></Placemark><Placemark><name>Dongara / Port Denison</name><styleUrl>#wpt</styleUrl><Point><coordinates>114.924200,-29.281400,0</coordinates></Point></Placemark><Placemark><name>Geraldton</name><styleUrl>#wpt</styleUrl><Point><coordinates>114.614700,-28.777400,0</coordinates></Point></Placemark><Placemark><name>Hutt Lagoon (pink lake)</name><styleUrl>#wpt</styleUrl><Point><coordinates>114.483900,-28.058600,0</coordinates></Point></Placemark><Placemark><name>Northampton</name><styleUrl>#wpt</styleUrl><Point><coordinates>114.436100,-27.875800,0</coordinates></Point></Placemark><Placemark><name>Kalbarri</name><styleUrl>#wpt</styleUrl><Point><coordinates>114.164700,-27.712800,0</coordinates></Point></Placemark></Folder>
<Folder><name>Scenic Points</name><Placemark><name>The Pinnacles</name><styleUrl>#poi</styleUrl><description><![CDATA[Thousands of limestone columns to 3.5 m tall in yellow sand — formed 25,000–30,000 years ago when leached calcium re-cemented around plant roots. Drive the 4 km loop or walk the trail at sunset.]]></description><Point><coordinates>115.158300,-30.604200,0</coordinates></Point></Placemark><Placemark><name>Cervantes / Lake Thetis stromatolites</name><styleUrl>#poi</styleUrl><description><![CDATA[Tiny lake just off the highway with living stromatolites — biofilm-built rocks made by cyanobacteria, the same life form that made Earth's atmosphere oxygen-bearing 3.5 billion years ago.]]></description><Point><coordinates>115.065300,-30.503700,0</coordinates></Point></Placemark><Placemark><name>Geraldton / HMAS Sydney memorial</name><styleUrl>#poi</styleUrl><description><![CDATA[Hilltop memorial to the 645 men lost when HMAS Sydney was sunk by the German raider Kormoran in November 1941 — Australia's worst naval disaster. The dome is built from 645 stainless-steel seagulls.]]></description><Point><coordinates>114.614700,-28.777400,0</coordinates></Point></Placemark><Placemark><name>Hutt Lagoon</name><styleUrl>#poi</styleUrl><description><![CDATA[10 km × 2 km lagoon coloured by Dunaliella salina algae — peak pink intensity is October to early summer, mid-morning to early afternoon. Drive the gravel loop on the western side.]]></description><Point><coordinates>114.483900,-28.058600,0</coordinates></Point></Placemark><Placemark><name>Kalbarri</name><styleUrl>#poi</styleUrl><description><![CDATA[Fishing village at the mouth of the Murchison. Pelicans fed daily on the foreshore at 8:45 AM. Whale sharks sometimes show offshore in winter; humpbacks pass May–November.]]></description><Point><coordinates>114.164700,-27.712800,0</coordinates></Point></Placemark><Placemark><name>Nature's Window</name><styleUrl>#poi</styleUrl><description><![CDATA[Wind-eroded sandstone arch framing the Murchison River gorge — the iconic Kalbarri photograph. 1 km return walk; do at sunrise to avoid the heat. Skywalk cantilever platforms 2 km further on.]]></description><Point><coordinates>114.169700,-27.655300,0</coordinates></Point></Placemark></Folder>
</Document></kml>
