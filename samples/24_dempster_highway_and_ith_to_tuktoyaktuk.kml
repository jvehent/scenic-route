<Folder><name>Waypoints</name><Placemark><name>Tombstone Territorial Park (km 71)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-138.220700,64.507700,0</coordinates></Point></Placemark><Placemark><name>Two Moose Lake (km 96)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-138.267000,64.658000,0</coordinates></Point></Placemark><Placemark><name>Engineer Creek (km 200)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-138.314000,65.404000,0</coordinates></Point></Placemark><Placemark><name>Ogilvie Ridge (km 258)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-138.418000,65.625000,0</coordinates></Point></Placemark><Placemark><name>Eagle Plains (km 369)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-136.717300,66.385800,0</coordinates></Point></Placemark><Placemark><name>Arctic Circle (km 405)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-136.295000,66.561100,0</coordinates></Point></Placemark><Placemark><name>Wright Pass / NWT border (km 465)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-136.480000,66.910000,0</coordinates></Point></Placemark><Placemark><name>Fort McPherson (km 549)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-134.881400,67.433900,0</coordinates></Point></Placemark><Placemark><name>Tsiigehtchic (km 608)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-133.750000,67.447000,0</coordinates></Point></Placemark><Placemark><name>Inuvik (km 736)</name><styleUrl>#wpt</styleUrl><Point><coordinates>-133.723000,68.359600,0</coordinates></Point></Placemark></Folder>
<Folder><name>Scenic Points</name><Placemark><name>Tombstone Territorial Park</name><styleUrl>#poi</styleUrl><description><![CDATA[Jagged black peaks ('the Patagonia of the North'), with an interpretive center and a campground. Late-August colors are world-class.]]></description><Point><coordinates>-138.220700,64.507700,0</coordinates></Point></Placemark><Placemark><name>Engineer Creek</name><styleUrl>#poi</styleUrl><description><![CDATA[Sulfurous springs stain the streambed bright orange. Iron-rich rock; smells like a struck match. Rough campground.]]></description><Point><coordinates>-138.314000,65.404000,0</coordinates></Point></Placemark><Placemark><name>Eagle Plains Hotel</name><styleUrl>#poi</styleUrl><description><![CDATA[Only services for hundreds of km in either direction. Fuel, beds, food, mechanic. Built directly on permafrost — the building leans gently with the seasons.]]></description><Point><coordinates>-136.717300,66.385800,0</coordinates></Point></Placemark><Placemark><name>Arctic Circle marker</name><styleUrl>#poi</styleUrl><description><![CDATA[Stand on 66°33′N. Sign and small parking pullout. Photo-op. North of here, the sun does not set on June 21st.]]></description><Point><coordinates>-136.295000,66.561100,0</coordinates></Point></Placemark><Placemark><name>Peel River ferry</name><styleUrl>#poi</styleUrl><description><![CDATA[Free year-round crossing — boat in summer, ice road in winter. During spring breakup and fall freeze-up the road is impassable.]]></description><Point><coordinates>-134.881400,67.433900,0</coordinates></Point></Placemark><Placemark><name>Igloo Church (Inuvik)</name><styleUrl>#poi</styleUrl><description><![CDATA[Our Lady of Victory — 1960 wooden Catholic church built in the shape of an igloo, painted blue and white. Open to visitors.]]></description><Point><coordinates>-133.723000,68.359600,0</coordinates></Point></Placemark><Placemark><name>Tuktoyaktuk pingos</name><styleUrl>#poi</styleUrl><description><![CDATA[Ice-cored hills — Tuk has the densest concentration on Earth (1,350 of them). Ibyuk, the largest, is 49 m tall and visible from town.]]></description><Point><coordinates>-133.036700,69.444100,0</coordinates></Point></Placemark></Folder>
</Document></kml>
