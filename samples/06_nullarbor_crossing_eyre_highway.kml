<Folder><name>Start / End</name><Placemark><name>START: Ceduna</name><styleUrl>#start</styleUrl><Point><coordinates>133.673100,-32.128100,0</coordinates></Point></Placemark><Placemark><name>END: Norseman</name><styleUrl>#end</styleUrl><Point><coordinates>121.779900,-32.199200,0</coordinates></Point></Placemark></Folder>
<Folder><name>Waypoints</name><Placemark><name>Penong</name><styleUrl>#wpt</styleUrl><Point><coordinates>133.014400,-31.925800,0</coordinates></Point></Placemark><Placemark><name>Nundroo</name><styleUrl>#wpt</styleUrl><Point><coordinates>132.227800,-31.770600,0</coordinates></Point></Placemark><Placemark><name>Yalata</name><styleUrl>#wpt</styleUrl><Point><coordinates>131.821700,-31.473300,0</coordinates></Point></Placemark><Placemark><name>Head of Bight turnoff</name><styleUrl>#wpt</styleUrl><Point><coordinates>131.171900,-31.496900,0</coordinates></Point></Placemark><Placemark><name>Nullarbor Roadhouse</name><styleUrl>#wpt</styleUrl><Point><coordinates>130.896700,-31.452000,0</coordinates></Point></Placemark><Placemark><name>Border Village (SA/WA)</name><styleUrl>#wpt</styleUrl><Point><coordinates>129.723900,-31.608300,0</coordinates></Point></Placemark><Placemark><name>Eucla</name><styleUrl>#wpt</styleUrl><Point><coordinates>128.883900,-31.678900,0</coordinates></Point></Placemark><Placemark><name>Mundrabilla</name><styleUrl>#wpt</styleUrl><Point><coordinates>128.220000,-31.827500,0</coordinates></Point></Placemark><Placemark><name>Madura</name><styleUrl>#wpt</styleUrl><Point><coordinates>127.022800,-31.914400,0</coordinates></Point></Placemark><Placemark><name>Cocklebiddy</name><styleUrl>#wpt</styleUrl><Point><coordinates>126.092800,-32.046700,0</coordinates></Point></Placemark><Placemark><name>Caiguna (start of 90 Mile Straight)</name><styleUrl>#wpt</styleUrl><Point><coordinates>125.488100,-32.268300,0</coordinates></Point></Placemark><Placemark><name>Balladonia</name><styleUrl>#wpt</styleUrl><Point><coordinates>123.856900,-32.452500,0</coordinates></Point></Placemark></Folder>
<Folder><name>Scenic Points</name><Placemark><name>Head of Bight</name><styleUrl>#poi</styleUrl><description><![CDATA[Between June and October, southern right whales calve directly below the 60 m Bunda Cliffs. Boardwalk and viewing platforms; a small entry fee supports the Yalata Aboriginal Community.]]></description><Point><coordinates>131.171900,-31.496900,0</coordinates></Point></Placemark><Placemark><name>Nullarbor Roadhouse</name><styleUrl>#poi</styleUrl><description><![CDATA[The proper middle-of-nowhere stop. Beside it is the only access road south to the cliffs of the Great Australian Bight (signposted detours every few km along the highway).]]></description><Point><coordinates>130.896700,-31.452000,0</coordinates></Point></Placemark><Placemark><name>Border Village</name><styleUrl>#poi</styleUrl><description><![CDATA[Quarantine inspection point — you cannot bring fresh fruit or vegetables across the WA border. Eat the apple before the gate. A 7 m fibreglass kangaroo, 'Rooey II,' guards the building.]]></description><Point><coordinates>129.723900,-31.608300,0</coordinates></Point></Placemark><Placemark><name>Eucla</name><styleUrl>#poi</styleUrl><description><![CDATA[Old telegraph station ruins half-buried in moving dunes. The 1877 station was abandoned in the 1920s as the dunes engulfed it. Climb the dunes for the eerie sight of stone walls emerging from sand.]]></description><Point><coordinates>128.883900,-31.678900,0</coordinates></Point></Placemark><Placemark><name>Caiguna — 90 Mile Straight</name><styleUrl>#poi</styleUrl><description><![CDATA[Marker at the start. 146.6 km of dead-straight bitumen ahead — the longest stretch of straight road in the world. Set cruise control, watch fuel, beware micro-sleeps.]]></description><Point><coordinates>125.488100,-32.268300,0</coordinates></Point></Placemark><Placemark><name>Balladonia</name><styleUrl>#poi</styleUrl><description><![CDATA[Where Skylab fell to Earth in July 1979. The roadhouse has fragments on display. The US handed Australia a $400 littering fine, paid by a California radio host.]]></description><Point><coordinates>123.856900,-32.452500,0</coordinates></Point></Placemark></Folder>
</Document></kml>
