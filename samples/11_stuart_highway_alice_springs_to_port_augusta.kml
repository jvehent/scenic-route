<Folder><name>Start / End</name><Placemark><name>START: Alice Springs</name><styleUrl>#start</styleUrl><Point><coordinates>133.880700,-23.698000,0</coordinates></Point></Placemark><Placemark><name>END: Port Augusta</name><styleUrl>#end</styleUrl><Point><coordinates>137.766900,-32.492200,0</coordinates></Point></Placemark></Folder>
<Folder><name>Waypoints</name><Placemark><name>Erldunda</name><styleUrl>#wpt</styleUrl><Point><coordinates>133.204200,-25.227200,0</coordinates></Point></Placemark><Placemark><name>Marla turnoff</name><styleUrl>#wpt</styleUrl><Point><coordinates>133.305000,-26.068100,0</coordinates></Point></Placemark><Placemark><name>Marla</name><styleUrl>#wpt</styleUrl><Point><coordinates>133.624400,-27.303300,0</coordinates></Point></Placemark><Placemark><name>Cadney Park</name><styleUrl>#wpt</styleUrl><Point><coordinates>133.951400,-27.723600,0</coordinates></Point></Placemark><Placemark><name>Coober Pedy</name><styleUrl>#wpt</styleUrl><Point><coordinates>134.754700,-29.013600,0</coordinates></Point></Placemark><Placemark><name>Ingomar</name><styleUrl>#wpt</styleUrl><Point><coordinates>134.984700,-29.635600,0</coordinates></Point></Placemark><Placemark><name>Glendambo</name><styleUrl>#wpt</styleUrl><Point><coordinates>135.746100,-30.963100,0</coordinates></Point></Placemark><Placemark><name>Pimba / Woomera turnoff</name><styleUrl>#wpt</styleUrl><Point><coordinates>136.783100,-31.246100,0</coordinates></Point></Placemark></Folder>
<Folder><name>Scenic Points</name><Placemark><name>Erldunda</name><styleUrl>#poi</styleUrl><description><![CDATA[Junction with the Lasseter Highway to Uluru. Roadhouse with an emu farm — the cassowary's slightly less impressive desert cousin. Last reasonable supplies before Coober Pedy.]]></description><Point><coordinates>133.204200,-25.227200,0</coordinates></Point></Placemark><Placemark><name>Coober Pedy</name><styleUrl>#poi</styleUrl><description><![CDATA[Opal-mining town producing ~70% of the world's opal. Summer surface temperatures pass 45 °C; most homes, shops, churches, and hotels are underground in disused mine workings. Tour a 'dugout' home.]]></description><Point><coordinates>134.754700,-29.013600,0</coordinates></Point></Placemark><Placemark><name>Glendambo</name><styleUrl>#poi</styleUrl><description><![CDATA[Population sign reads 'Sheep 22,500 / Flies 2,000,000 / People 30.' Roadhouse with caravan park; nothing else. Long, flat, treeless plain begins to lift toward the Flinders Ranges.]]></description><Point><coordinates>135.746100,-30.963100,0</coordinates></Point></Placemark><Placemark><name>Woomera (turnoff)</name><styleUrl>#poi</styleUrl><description><![CDATA[Cold War rocket-test range — UK and Australian missile testing site from 1947. Open-air museum of decommissioned missiles and aircraft (free). Active range still — observe the warning signs.]]></description><Point><coordinates>136.783100,-31.246100,0</coordinates></Point></Placemark><Placemark><name>Port Augusta</name><styleUrl>#poi</styleUrl><description><![CDATA[Where the desert meets Spencer Gulf. The Australian Arid Lands Botanic Garden on the northern outskirts is the best collection of central-Australian flora anywhere. Flinders Ranges visible to the east.]]></description><Point><coordinates>137.766900,-32.492200,0</coordinates></Point></Placemark></Folder>
</Document></kml>
